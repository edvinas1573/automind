{
  "entities": {
    "CachedCar": {
      "title": "CachedCar",
      "description": "Metadata for cached car images",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "year": { "type": "string" },
        "imageUrls": {
          "type": "array",
          "items": { "type": "string" }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "year", "imageUrls", "createdAt"]
    }
  },
  "firestore": {
    "cached_cars": {
      "schema": "CachedCar",
      "description": "Collection of cached car image metadata"
    }
  }
}
